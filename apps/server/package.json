{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@mulai-plus/api": "workspace:*",
    "@mulai-plus/auth": "workspace:*",
    "@mulai-plus/db": "workspace:*",
    "@mulai-plus/env": "workspace:*",
    "@mulai-plus/r2": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@sentry/bun": "^10.58.0",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "hono-rate-limiter": "^0.5.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "tsdown": "^0.16.5",
    "@mulai-plus/config": "workspace:*"
  }
}
