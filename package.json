{
  "name": "mulai-plus",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "^1.4.9",
      "@orpc/client": "^1.12.2"
    }
  },
  "type": "module",
  "scripts": {
    "check": "biome check --write .",
    "prepare": "husky",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "build:web": "turbo -F web build",
    "build:server": "turbo -F server build",
    "docker:stage": "docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build",
    "docker:stage:down": "docker compose -f docker-compose.staging.yml --env-file .env.staging down",
    "docker:stage:logs": "docker compose -f docker-compose.staging.yml --env-file .env.staging logs -f",
    "db:push": "turbo -F @mulai-plus/db db:push",
    "db:studio": "turbo -F @mulai-plus/db db:studio",
    "db:generate": "turbo -F @mulai-plus/db db:generate",
    "db:migrate": "turbo -F @mulai-plus/db db:migrate"
  },
  "dependencies": {
    "@mulai-plus/env": "workspace:*",
    "@supabase/supabase-js": "^2.91.1",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "@biomejs/biome": "^2.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "typescript": "catalog:",
    "@types/bun": "catalog:",
    "@mulai-plus/config": "workspace:*"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --unsafe"
    ]
  },
  "packageManager": "bun@1.2.19"
}
