# Environment Variables Template
# Copy to .env.local or .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/mulai_plus

# ===========================================
# BETTER AUTH
# ===========================================
# Secret key for session encryption (min 32 chars)
BETTER_AUTH_SECRET=your-better-auth-secret-at-least-32-characters-long
# Base URL of the server
BETTER_AUTH_URL=http://localhost:3000
# Allowed origin for CORS
CORS_ORIGIN=http://localhost:3001

# ===========================================
# CLOUDFLARE R2 STORAGE
# ===========================================
# Account ID from Cloudflare dashboard
R2_ACCOUNT_ID=your-cloudflare-account-id
# R2 API Token credentials (not the global API key)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Name of the R2 bucket
R2_BUCKET_NAME=mulai-plus-media
# Public URL prefix for accessing files (can be custom domain or R2.dev URL)
R2_PUBLIC_URL=https://cdn.example.com

# ===========================================
# PAYMENT API
# ===========================================
PAYMENT_API_URL=https://api.payment.example.com
PAYMENT_API_KEY=your-payment-api-key

# ===========================================
# GOOGLE OAUTH
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# EMAIL (Optional)
# ===========================================
UNOSEND_API_KEY=your-unosend-api-key
UNOSEND_FROM_EMAIL=hello@example.com

# ===========================================
# SERVER
# ===========================================
PORT=3000
NODE_ENV=development